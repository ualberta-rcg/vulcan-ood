#!/bin/bash

echo "[before.sh.erb] Starting AlphaFold setup..."

# Export the module function if available (script needs it for module load)
if [[ $(type -t module) == "function" ]]; then
  echo "[before.sh.erb] 'module' function is available."
  export -f module
else
  echo "[before.sh.erb] WARNING: 'module' function not available."
fi

# Needed for Alliance clusters
export CC_CLUSTER=vulcan

# Job dir (logs, helper files)
export JOB_DIR="$PWD"
echo "[before.sh.erb] JOB_DIR=${JOB_DIR}"

USER_NAME="${USER:-$(whoami)}"
echo "[before.sh.erb] USER_NAME: $USER_NAME"
echo "[before.sh.erb] HOME: ${HOME}"

PROJECT_ACCOUNT="default"
export PROJECT_ROOT="/uhome/${USER_NAME}/projects/${PROJECT_ACCOUNT}"
echo "[before.sh.erb] PROJECT_ROOT: ${PROJECT_ROOT}"
mkdir -p "${PROJECT_ROOT}"

echo "[before.sh.erb] AlphaFold setup complete."
