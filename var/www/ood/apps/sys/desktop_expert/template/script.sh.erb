#!/usr/bin/env bash
# script.sh.erb — main desktop launch hook (OOD batch_connect 'script').
# before.sh.erb already ran: runtime dirs, env cleanup, and GPU/VirtualGL setup.

echo "[script.sh.erb] Starting desktop environment setup for user: $USER"
echo "[script.sh.erb] Working directory: $HOME"
cd "${HOME}" || {
  echo "[script.sh.erb] ERROR: Failed to change to home directory: $HOME"
  exit 1
}

# Reset modules to a clean state
echo "[script.sh.erb] Purging and restoring modules..."
module purge && module restore

# Login shell (from env, set when the session started — no NSS lookup)
export SHELL="${SHELL:-/bin/bash}"
echo "[script.sh.erb] SHELL set to: $SHELL"

# Allow local user connections (Firefox etc.)
xhost +SI:localuser:"$USER" 2>/dev/null || true

echo "[script.sh.erb] websockify listening on port: ${WEBSOCKIFY_PORT:-unknown (see websockify.log)}"

# Background GL probe: confirms (in output.log) whether GL is hardware-accelerated.
# Runs once after the desktop is up. Non-fatal if glxinfo is absent.
(
  sleep 12
  if command -v glxinfo >/dev/null 2>&1; then
    renderer="$(glxinfo -B 2>/dev/null | awk -F': ' '/OpenGL renderer string/{print $2; exit}')"
    echo "[script.sh.erb] GL probe → OpenGL renderer: ${renderer:-<none / glxinfo failed>}"
    case "${renderer,,}" in
      *llvmpipe*|*softpipe*|*swrast*) echo "[script.sh.erb] WARNING: software rendering in use (GPU not engaged)";;
      *) echo "[script.sh.erb] OK: hardware GL renderer active";;
    esac
  else
    echo "[script.sh.erb] GL probe skipped (glxinfo not installed)"
  fi
) &

# Launch the chosen desktop
echo "[script.sh.erb] Launching desktop session: '<%= context.desktop %>'..."
DESKTOP_SCRIPT="<%= session.staged_root.join("desktops", "#{context.desktop}.sh") %>"

if [[ -x "$DESKTOP_SCRIPT" ]]; then
  echo "[script.sh.erb] Executing desktop startup script: $DESKTOP_SCRIPT"
  source "$DESKTOP_SCRIPT"
  echo "[script.sh.erb] Desktop session '<%= context.desktop %>' exited with status $?"
else
  echo "[script.sh.erb] ERROR: Desktop script not found or not executable: $DESKTOP_SCRIPT"
  exit 1
fi
