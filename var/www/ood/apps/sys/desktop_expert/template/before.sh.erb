#!/bin/bash
# before.sh.erb — runs once before the desktop launch (OOD batch_connect 'before' hook).
# Identity is established by OIDC at login: $USER is the LDAP username, authoritative.

# Export module function into non-login shells spawned later
[[ $(type -t module) == "function" ]] && export -f module

# --- Identity (no NSS lookups — OIDC user is already the running process) ---
USER_NAME="${USER:-$(whoami)}"
USER_UID="$(id -u)"
echo "[before.sh.erb] User: $USER_NAME (UID: $USER_UID)"

# --- Runtime dirs (needs root): /tmp/.ICE-unix + symlink /run/user/$UID -> xdg-runtime ---
sudo /usr/local/bin/create-ice.sh "$USER_UID"

# Working dir for OOD launch scripts
export OOD_DIR="${PWD}"

# --- Strip login-shell leftovers that confuse desktop sessions ---
unset DBUS_SESSION_BUS_ADDRESS DBUS_SESSION_BUS_PID
unset XDG_SESSION_TYPE WAYLAND_DISPLAY
unset $(env | grep -o '^BASH_FUNC_.*%%' | cut -d= -f1) 2>/dev/null || true

# XDG_RUNTIME_DIR (create-ice symlinks /run/user/$UID to this)
export XDG_RUNTIME_DIR="/tmp/xdg-runtime-$USER_UID"
mkdir -p "$XDG_RUNTIME_DIR"
chmod 700 "$XDG_RUNTIME_DIR"
echo "[before.sh.erb] XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR"

# --- GPU / VirtualGL (one place, used by all desktops) ---
# Use libvglfaker-nodl ONLY: libdlfaker hooks dlopen() and breaks app stacks.
# EGL backend renders GL on the GPU, reads back into the TurboVNC framebuffer.
VGL_LIB_PATH="/usr/lib"
VGL_FAKER="${VGL_LIB_PATH}/libvglfaker-nodl.so"
GPU_PRESENT=$(nvidia-smi --query-gpu=name --format=csv,noheader,nounits 2>/dev/null | grep -v "^$" | head -n 1)

if [[ -n "$GPU_PRESENT" && "$GPU_PRESENT" != "No devices were found" && -f "$VGL_FAKER" ]]; then
  export OOD_GPU_AVAILABLE=true
  export VGL_DISPLAY=egl
  export LD_PRELOAD="$VGL_FAKER${LD_PRELOAD:+:${LD_PRELOAD}}"
  echo "[before.sh.erb] GPU detected: $GPU_PRESENT"
  echo "[before.sh.erb] VirtualGL enabled (libvglfaker-nodl + EGL backend)"
else
  export OOD_GPU_AVAILABLE=false
  export LIBGL_ALWAYS_SOFTWARE=1
  export QT_QUICK_BACKEND=software
  echo "[before.sh.erb] No GPU / VirtualGL — software rendering"
fi

echo "[before.sh.erb] Setup complete."

# --- Chrome: exempt from the VGL faker + disable its sandbox/GPU ---
# OOD jobs lack the user namespaces Chrome's sandbox needs (zygote broken-pipe
# crash). Chrome is exempt from VGL (browsing needs no GPU accel) and its GPU
# process can't init against TurboVNC anyway, so disable it for clean software
# rendering. Done via a per-user .desktop override (takes precedence over the
# system one in menu launchers, which call the absolute binary path).
CHROME_SRC="/usr/share/applications/google-chrome.desktop"
CHROME_DST="${HOME}/.local/share/applications/google-chrome.desktop"
if [[ -f "$CHROME_SRC" ]]; then
  mkdir -p "$(dirname "$CHROME_DST")"
  sed -e 's#^Exec=/usr/bin/google-chrome-stable#Exec=env -u LD_PRELOAD /usr/bin/google-chrome-stable --no-sandbox --disable-gpu-sandbox --disable-gpu#' \
      "$CHROME_SRC" > "$CHROME_DST"
  chmod 644 "$CHROME_DST"
  echo "[before.sh.erb] Chrome launcher patched (--no-sandbox, --disable-gpu, no VGL faker)"
fi

# --- Default browser = Chrome (freedesktop mimeapps.list + GNOME gsettings) ---
# xdg-settings alone is ignored by GNOME; mimeapps.list is respected by all DEs.
if command -v xdg-mime >/dev/null 2>&1; then
  xdg-mime default google-chrome.desktop \
    text/html x-scheme-handler/http x-scheme-handler/https \
    x-scheme-handler/about x-scheme-handler/unknown \
    application/xhtml+xml application/pdf 2>/dev/null || true
fi
gsettings set org.gnome.desktop.default-applications.browser exec 'google-chrome' 2>/dev/null || true
echo "[before.sh.erb] Default browser set to Chrome"
