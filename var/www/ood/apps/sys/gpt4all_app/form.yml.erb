<%
app_name = "GPT4All"
%>
---
title: <%= app_name %>
attributes:
  cluster:
    widget: select
    label: Cluster
    options:
      - "<%= CustomClusterInfo.cluster_name %>"
  num_cores:
    widget: number_field
    label: "Number of CPU cores"
    value: 4
    min: 2
    max: 64
    step: 1
  bc_num_hours:
    widget: number_field
    label: "Number of hours"
    value: 2
    min: 1
    max: 8
    step: 1
form:
  - cluster
  - num_cores
  - bc_num_hours
