<%
app_name = "GPT4All"
template_root = "/var/www/ood/apps/templates/"
min_cores = 4
min_mem_gb = 4
%>
---
title: <%= app_name %>

attributes:
  cluster:
    widget: select
    label: Cluster
    options:
      - "<%= CustomClusterInfo.cluster_name %>"

<% IO.foreach(template_root+"job_params") do |line| %><%= line %><% end %>

  memtask_checkbox:
    value: "1"
    cacheable: false
    widget: hidden_field

form:
  - cluster
  - bc_num_hours
  - num_cores
  - memtask_checkbox
  - memtask
  - add_env_checkbox
  - additional_environment
  - bc_email_on_started
