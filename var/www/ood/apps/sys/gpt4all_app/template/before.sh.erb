#!/bin/bash

echo "[before.sh.erb] Starting GPT4All Setup..."

# Export the module function if available
if [[ $(type -t module) == "function" ]]; then
  echo "[before.sh.erb] 'module' function is available."
  export -f module
else
  echo "[before.sh.erb] WARNING: 'module' function not available."
fi

# Find available port to run server on
export port=$(find_port ${host})
if [[ -z "$port" ]]; then
  echo "[before.sh.erb] ERROR: Failed to allocate a port."
  exit 1
else
  echo "[before.sh.erb] Selected available port: $port"
fi

# Generate secure password for GPT4All
export password="$(create_passwd 16)"
echo "[before.sh.erb] Generated GPT4All password: $password"

# Needed for Alliance Clusters
export CC_CLUSTER=vulcan

# GPT4All working directory (data and logs; GPT4All binary comes from CVMFS module)


# Create GPT4All working directory
if [[ $? -ne 0 ]]; then
  exit 1
else
fi

echo "[before.sh.erb] GPT4All setup complete (using CVMFS module openrefine/3.9.3)."
