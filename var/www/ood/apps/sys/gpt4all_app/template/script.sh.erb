#!/usr/bin/env bash
set -euo pipefail
echo "[script.sh.erb] GPT4All session for $USER"

# --- CVMFS Python ---
module purge 2>/dev/null
module load StdEnv/2023 python/3.12.4 2>/dev/null
echo "[script.sh.erb] Python: $(python3 --version)"

# --- venv in $SCRATCH (persists across sessions) ---
VENV="${SCRATCH:-$HOME/scratch}/gpt4all-venv"
if [[ ! -d "$VENV" ]]; then
  echo "[script.sh.erb] Creating venv at $VENV ..."
  python3 -m venv "$VENV"
fi
source "$VENV/bin/activate"
echo "[script.sh.erb] venv active: $(which python3)"

# --- install gpt4all + gradio if needed ---
if ! python3 -c "import gpt4all" 2>/dev/null; then
  echo "[script.sh.erb] Installing gpt4all + gradio (first run, ~2 min) ..."
  pip install --upgrade pip
  pip install gpt4all gradio
fi

# --- download a default model if none present ---
MODEL_DIR="${SCRATCH:-$HOME/scratch}/gpt4all-models"
mkdir -p "$MODEL_DIR"
cat > "${VENV}/gpt4all_chat.py" <<'PY'
import gradio as gr
from gpt4all import GPT4All
import os, sys, glob

MODEL_DIR = os.environ.get("GPT4ALL_MODEL_DIR", os.path.expanduser("~/gpt4all-models"))
DEFAULT_MODEL = "orca-mini-3b-gguf2-q4_0"

# Find any existing downloaded model
models = glob.glob(os.path.join(MODEL_DIR, "*.bin")) + glob.glob(os.path.join(MODEL_DIR, "*.gguf"))
model_name = os.path.basename(models[0]) if models else DEFAULT_MODEL

print(f"[GPT4All] Loading model: {model_name}", flush=True)
try:
    model = GPT4All(model_name, model_path=MODEL_DIR, allow_download=True)
except Exception as e:
    print(f"[GPT4All] Error loading model: {e}", file=sys.stderr)
    sys.exit(1)

print("[GPT4All] Model loaded. Starting Gradio chat ...", flush=True)

def chat(message, history):
    response = model.chat(message)
    return response

demo = gr.ChatInterface(fn=chat, title="GPT4All — Local LLM Chat",
                         description=f"Model: {model_name} (running offline on CPU)")
demo.launch(server_name="0.0.0.0", server_port=int("${port}"))
PY

export GPT4ALL_MODEL_DIR="$MODEL_DIR"
echo "[script.sh.erb] Launching Gradio chat on port ${port} ..."
python3 "${VENV}/gpt4all_chat.py"
