#!/bin/bash

echo "[script.sh.erb] Starting GPT4All Server"

cd "${HOME}"

# --- CVMFS Python ---
module purge
module load StdEnv/2023 python/3.12.4
echo "[script.sh.erb] Python: $(python3 --version)"

# --- venv in $SCRATCH (persists across sessions) ---
VENV="${SCRATCH:-$HOME/scratch}/gpt4all-venv"
if [[ ! -d "$VENV" ]]; then
  echo "[script.sh.erb] Creating venv at $VENV ..."
  python3 -m venv "$VENV"
fi
source "$VENV/bin/activate"

# --- install gpt4all + gradio if needed ---
if ! python3 -c "import gpt4all" 2>/dev/null; then
  echo "[script.sh.erb] Installing gpt4all + gradio (first run, ~2 min) ..."
  pip install --upgrade pip
  pip install gpt4all gradio setuptools
fi

# --- model directory ---
MODEL_DIR="${SCRATCH:-$HOME/scratch}/gpt4all-models"
mkdir -p "$MODEL_DIR"

# --- write the Gradio chat server ---
cat > "${VENV}/gpt4all_server.py" << 'PYEOF'
import gradio as gr
from gpt4all import GPT4All
import os, glob, sys

MODEL_DIR = os.environ.get("GPT4ALL_MODEL_DIR", os.path.expanduser("~/gpt4all-models"))
PORT = int(os.environ.get("port", "7860"))
DEFAULT = "orca-mini-3b-gguf2-q4_0"

existing = glob.glob(os.path.join(MODEL_DIR, "*.bin")) + glob.glob(os.path.join(MODEL_DIR, "*.gguf"))
name = os.path.basename(existing[0]) if existing else DEFAULT

print(f"[GPT4All] Loading model: {name}", flush=True)
try:
    model = GPT4All(name, model_path=MODEL_DIR, allow_download=True)
except Exception as e:
    print(f"[GPT4All] ERROR: {e}", file=sys.stderr)
    sys.exit(1)

print(f"[GPT4All] Serving Gradio chat on port {PORT} ...", flush=True)
gr.ChatInterface(
    fn=lambda msg, hist: model.chat(msg),
    title="GPT4All — Local LLM Chat",
    description=f"Model: {name} (offline on CPU)",
).launch(server_name="0.0.0.0", server_port=PORT)
PYEOF

export GPT4ALL_MODEL_DIR="$MODEL_DIR"

# Launch GPT4All Gradio server
echo "[script.sh.erb] Launching GPT4All on port ${port} ..."
python3 "${VENV}/gpt4all_server.py"
