#!/usr/bin/env bash
echo "[script.sh.erb] session for $USER at $(date)"
cd "${HOME}" || { echo "ERROR: no home"; exit 1; }
module purge 2>/dev/null; module restore 2>/dev/null
export SHELL="${SHELL:-/bin/bash}"
xhost +SI:localuser:"$USER" 2>/dev/null || true

TARGET="${OOD_APP_LAUNCH:-}"
APP="${OOD_APP_CMD:-}"
if [[ -n "$TARGET" ]]; then
  if ! module load "$TARGET" 2>/dev/null; then
    PREREQS=$(module spider "$TARGET" 2>&1 \
      | awk '/You will need to load all module\(s\)/,/^ *Help:/' \
      | grep -Eo '[A-Za-z0-9._/-]+/[0-9][A-Za-z0-9._-]*' | sort -u \
      | grep -v "^${TARGET}$")
    [[ -n "$PREREQS" ]] && { echo "[script.sh.erb] prereqs: $PREREQS"; module load $PREREQS 2>/dev/null; }
    module load "$TARGET" 2>/dev/null
  fi
fi
[[ -z "$APP" ]] && APP=$(echo "$TARGET" | awk -F/ '{print $1}')
command -v "$APP" >/dev/null 2>&1 || { echo "[script.sh.erb] ERROR: '$APP' not on PATH after loading $TARGET"; sleep 30; exit 1; }

( xfwm4 --daemon >/dev/null 2>&1 & ) 2>/dev/null
sleep 1
echo "[script.sh.erb] Launching $APP ..."
if [[ "$OOD_GPU_AVAILABLE" == "true" ]]; then "$APP" & else LIBGL_ALWAYS_SOFTWARE=1 "$APP" & fi
wait $!
echo "[script.sh.erb] session ended"
