<%-
  # Resolve the user's email from the OIDC claim captured by the PUN pre-hook
  # (/opt/ood/scripts/ood_pun_oidc_email.sh writes ~/ondemand/oidc_email.txt).
  emailaddr = File.read(File.expand_path('~/ondemand/oidc_email.txt')).strip rescue ''

  # Site-wide shared Vulcan Tyk key (all users, until per-user keys roll out). Root-owned
  # at /opt/ood/vulcan_tyk.key; injected into the job env here (rendered on the web node) so
  # it reaches the compute node. A per-user ~/.env_tyk overrides it (see script.sh.erb).
  vulcan_tyk = File.read('/opt/ood/vulcan_tyk.key').strip rescue ''
-%>

batch_connect:
  template: "basic"

script:
  cluster: "<%= cluster %>"
  job_environment:
    # Shared Vulcan Tyk gateway key (all users). Overridden by a per-user ~/.env_tyk
    # in script.sh.erb once per-user keys are rolled out.
    CF_VULCAN_API_KEY: "<%= vulcan_tyk %>"
  <% if defined?(bc_email_on_started) && bc_email_on_started == "1" && emailaddr != "" %>
  email: <%= emailaddr.inspect %>
  <% end %>
  native:
    - "-N"
    - "1"
    - "-n"
    - "<%= num_cores %>"
    - "--time=<%= bc_num_hours %>:00:00"
    <%-# Always request a memory floor (Slurm's default is ~500 MB, which OOMs the
        -# chainforge install). Use the user's choice if they enabled it, else 4 GB. -%>
    <%- memval = (defined?(memtask_checkbox) && memtask_checkbox == "1" && memtask.present? && memtask != "0") ? "#{memtask}G" : "4G" -%>
    - "--mem=<%= memval %>"
    # Use the same interactive partition as the other Vulcan apps.
    # No --gres is requested: ChainForge only calls external LLM APIs and needs no GPU.
    - "--partition=gpubase_interac"
